g the log-log plot with the fit. All these steps will be consolidated into a single code block for clarity and proper data flow.\n","\n"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"43e9e644","executionInfo":{"status":"ok","timestamp":1769929980092,"user_tz":300,"elapsed":828,"user":{"displayName":"Will Lenchus","userId":"03870594209213912784"}},"outputId":"817120b7-ad3d-4b7d-b5c4-ff52a8e3cb8d"},"source":["import numpy as np\n","import matplotlib.pyplot as plt\n","from scipy.optimize import curve_fit\n","\n","# --- Parameters from previous cells --- (Ensuring they are available if running standalone)\n","eps0 = 8.854e-12      # Permittivity of vacuum [F/m]\n","mu0 = 4*np.pi*1e-7    # Permeability of vacuum [H/m]\n","c = 1/np.sqrt(eps0*mu0)\n","\n","def reflection_coefficient(omega, theta_deg, sigma, d_f):\n","    \"\"\"\n","    Implements Liu et al. Eq. (5) for ultrathin conductive film.\n","    \"\"\"\n","    theta = np.deg2rad(theta_deg)\n","    beta = sigma * omega * mu0 * d_f**2\n","    gamma = np.sqrt(sigma / (omega * eps0)) * np.cos(theta)\n","    sqrt_i = np.exp(1j * np.pi/4)\n","    sqrt_i_beta = np.sqrt(1j * beta)\n","    numerator = - (1j + gamma**2) * np.sin(sqrt_i_beta)\n","    denominator = (2 * sqrt_i * gamma * np.cos(sqrt_i_beta) +\n","                   (-1j + gamma**2) * np.sin(sqrt_i_beta))\n","    r = numerator / denominator\n","    return r\n","\n","# Re-define main analysis parameters for clarity and potential re-execution\n","f0 = 0.3e12  # 0.3 THz\n","omega0 = 2*np.pi*f0\n","sigma = 1.12e5  # Point P2 conductivity\n","d_f = 10e-6     # Film thickness\n","\n","# Calculate pseudo-Brewster angle\n","theta_c = np.arccos(np.sqrt(omega0 * eps0 / sigma))\n","theta_c_deg = np.rad2deg(theta_c)\n","\n","print(f\"Pseudo-Brewster angle: {theta_c_deg:.2f}°\")\n","\n","# 1. Define a very fine angular grid\n","theta_fine_exp = np.linspace(theta_c_deg - 0.15, theta_c_deg - 1e-5, 500)\n","\n","# 2. Calculate absorption A_fine_exp\n","A_fine_exp = np.zeros_like(theta_fine_exp)\n","for i, th in enumerate(theta_fine_exp):\n","    r = reflection_coefficient(omega0, th, sigma, d_f)\n","    A_fine_exp[i] = 1 - np.abs(r)**2 # Assuming T->0 for opaque films\n","\n","# 3. Compute dtheta_values and dA_values\n","dtheta_values = theta_c_deg - theta_fine_exp\n","HBAR_absorption_limit = 2*np.sqrt(2)-2\n","dA_values = HBAR_absorption_limit - A_fine_exp\n","\n","# 4. Create a plot of dA_values versus dtheta_values on a linear scale\n","plt.figure(figsize=(8, 6))\n","plt.plot(dtheta_values, dA_values, 'o-', markersize=4, label='Raw Deviations')\n","plt.xlabel('dθ (degrees)')\n","plt.ylabel('dA (Absorption)')\n","plt.title('Raw Deviation from HBAR Wall (Linear Scale)')\n","plt.grid(True)\n","plt.legend()\n","plt.savefig('raw_deviations_linear.png', dpi=150)\n","plt.show()\n","\n","# 5. Apply logarithmic transformation\n","epsilon = 1e-10 # Small value to avoid log(0) and handle negative dA values near zero\n","log_dtheta = np.log(dtheta_values)\n","log_dA = np.log(np.abs(dA_values) + epsilon)\n","\n","# 6. Filter out non-finite values\n","valid_indices = np.isfinite(log_dtheta) & np.isfinite(log_dA)\n","\n","# Plot raw log(dA) vs log(dtheta) for visual inspection and fitting\n","plt.figure(figsize=(10, 7))\n","plt.scatter(log_dtheta[valid_indices], log_dA[valid_indices], label='Calculated log(dA) points', s=10, c='blue')\n","plt.xlabel('log(dθ)')\n","plt.ylabel('log(dA)')\n","plt.title('Log-Log Plot: log(dA) vs log(dθ) for Critical Exponent Analysis')\n","plt.grid(True)\n","\n","nu1, nu2 = np.nan, np.nan # Initialize\n","\n","if np.sum(valid_indices) > 1:\n","\n","    # Define specific fitting ranges for log(dtheta) as requested\n","    # Region 1: Right of collapse (larger dtheta, less negative log_dtheta)\n","    fit_range_right_min = -3.0 # Example: dtheta ~0.05\n","    fit_range_right_max = -2.0 # Example: dtheta ~0.13\n","\n","    # Region 2: Left of collapse (smaller dtheta, more negative log_dtheta)\n","    fit_range_left_min = -6.0  # Example: dtheta ~0.0025\n","    fit_range_left_max = -4.5  # Example: dtheta ~0.01\n","\n","    # Filter data for Region 1 (Right of collapse)\n","    mask_right = (log_dtheta[valid_indices] >= fit_range_right_min) & \\\n","                 (log_dtheta[valid_indices] <= fit_range_right_max)\n","    log_dtheta_right_fit = log_dtheta[valid_indices][mask_right]\n","    log_dA_right_fit = log_dA[valid_indices][mask_right]\n","\n","    # Filter data for Region 2 (Left of collapse)\n","    mask_left = (log_dtheta[valid_indices] >= fit_range_left_min) & \\\n","                (log_dtheta[valid_indices] <= fit_range_left_max)\n","    log_dtheta_left_fit = log_dtheta[valid_indices][mask_left]\n","    log_dA_left_fit = log_dA[valid_indices][mask_left]\n","\n","    # Perform fit for Region 1 (Right)\n","    if len(log_dtheta_right_fit) > 1:\n","        coeffs1 = np.polyfit(log_dtheta_right_fit, log_dA_right_fit, 1)\n","        nu1 = coeffs1[0]\n","        fit_line1 = coeffs1[0] * log_dtheta_right_fit + coeffs1[1]\n","        plt.plot(log_dtheta_right_fit, fit_line1, color='green', linestyle='--', label=f'Fit Right (nu1 = {nu1:.4f})')\n","    else:\n","        print(\"Not enough data points for 'right' region fit. Adjust ranges.\")\n","\n","    # Perform fit for Region 2 (Left)\n","    if len(log_dtheta_left_fit) > 1:\n","        coeffs2 = np.polyfit(log_dtheta_left_fit, log_dA_left_fit, 1)\n","        nu2 = coeffs2[0]\n","        fit_line2 = coeffs2[0] * log_dtheta_left_fit + coeffs2[1]\n","        plt.plot(log_dtheta_left_fit, fit_line2, color='orange', linestyle='--', label=f'Fit Left (nu2 = {nu2:.4f})')\n","    else:\n","        print(\"Not enough data points for 'left' region fit. Adjust ranges.\")\n","\n","    print(f\"\\nCritical exponent nu1 (region right of collapse, log(dθ) range [{fit_range_right_min}, {fit_range_right_max}]) = {nu1:.4f}\")\n","    print(f\"Critical exponent nu2 (region left of collapse, log(dθ) range [{fit_range_left_min}, {fit_range_left_max}]) = {nu2:.4f}\")\n","    print(f\"TEP prediction: nu = 0.5 or 1.0 (metric singularity)\")\n","    print(f\"Standard EM: nu = 2.0 (Gaussian) or 1.0 (Lorentzian)\")\n","else:\n","    print(\"Not enough valid data points for any fit.\")\n","\n","plt.legend()\n","plt.savefig('critical_exponent_loglog_two_fits_refined_ranges.png', dpi=150)\n","plt.show()"],"execution_count":63,"outputs":[{"output_type":"stream","name":"stdout","text":["Pseudo-Brewster angle: 89.30°\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","Critical exponent nu1 (region right of collapse, log(dθ) range [-3.0, -2.0]) = 1.9897\n","Critical exponent nu2 (region left of collapse, log(dθ) range [-6.0, -4.5]) = -0.3093\n","TEP prediction: nu = 0.5 or 1.0 (metric singularity)\n","Standard EM: nu = 2.0 (Gaussian) or 1.0 (Lorentzian)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x700 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","metadata":{"id":"a0d45fcf"},"source":["## Re-examine Berry Phase in Budget Space\n","\n","### Subtask:\n","Thoroughly revisit the `compute_berry_phase_in_budget_space` function, clarify its theoretical basis, and ensure correct encirclement of the critical point for an accurate Berry phase calculation.\n"]},{"cell_type":"markdown","metadata":{"id":"8dd6522d"},"source":["### Re-examination of Berry Phase in Budget Space: Theoretical Clarification\n","\n","#### 1. Theoretical Basis of `compute_berry_phase_in_budget_space`\n","\n","The `compute_berry_phase_in_budget_space` function attempts to calculate a Pancharatnam-Berry phase by constructing a pseudo-spinor `|ψ> = [√x², i√u]` where `x²` represents reflection and `u` represents absorption. This approach is common in Topological Electromagnetism (TEP) as it maps the energy budget onto a projective Hilbert space, allowing for the calculation of geometric phases. The key idea is that a non-trivial Berry phase (typically `π` for a Z₂ invariant) indicates an underlying topological defect (e.g., a branch point or exceptional point) enclosed by the integration path in the parameter space.\n","\n","However, several ambiguities and discrepancies have arisen:\n","\n","*   **Interpretation of `gamma`**: The `gamma` parameter in the `reflection_coefficient` function is `np.sqrt(sigma / (omega * eps0)) * np.cos(theta)`. In the `compute_berry_phase_in_budget_space` function, `gamma_path` is treated as a complex parameter. The relationship between the `gamma` from the reflection coefficient formula and the `gamma` used in the budget space formulation (`x = np.sqrt(2*gamma_path - 1)`, `u = np.sqrt(2*(1 - gamma_path))`) needs precise clarification from the theoretical source. It seems the latter `gamma` is an abstract budget parameter, distinct from the `gamma` in Liu et al.'s reflection formula.\n","\n","*   **`gamma_star` Definition**: The `gamma_star = 2 - np.sqrt(2) \\approx 0.586` is identified as the point where `x² = u` (i.e., reflection equals absorption) under the budget formulation `x² = 2γ - 1` and `u = 2(1-γ)`. This `gamma_star` is a critical point in the budget space, but it's essential to understand if encircling *this specific* `gamma_star` is topologically significant for the HBAR wall in the context of the Liu et al. model, and how it relates to the reflection coefficient `r` which showed no singularities.\n","\n","*   **State Vector Construction (`|ψ> = [√x², i√u]`)**: While this form is standard for energy budgets, its applicability when `gamma_path` is complex needs careful validation. If `gamma_path` is complex, then `x` and `u` will also be complex, and `√x²` and `√u` will involve square roots of complex numbers, potentially introducing multi-valuedness that needs to be handled consistently (e.g., by choosing a principal branch).\n","\n","#### 2. Discrepancies and Previous Findings\n","\n","Previous analyses revealed that:\n","\n","*   The `reflection_coefficient` function (Liu et al. Eq. 5) *itself* does not exhibit any zeros or poles in the `(ω, θ)` parameter space, nor does `arg(r)` show any `π` phase jumps. This suggests a classical electromagnetic behavior without the expected topological features for the reflection coefficient directly.\n","*   The winding number calculation around the critical region was `0.0000`.\n","*   The `compute_berry_phase_in_budget_space` function yielded `6.1711` radians (`\\approx 2π`), which was interpreted as a *trivial* Berry phase (no topological defect enclosed). This contradicts the expectation that the HBAR wall *should* be a topological feature. This trivial result is consistent with the lack of singularities in `r` itself.\n","\n","#### 3. Clarifying `gamma_star` and the Topological Interpretation\n","\n","The most critical aspect here is reconciling the abstract budget space (`gamma`) with the physical `reflection_coefficient`. If the `gamma` in the budget formulation is *not* directly derived from the parameters in the `reflection_coefficient` function in a way that maps its singularities, then the Berry phase in this abstract budget space may not directly reflect the topology of the *physical system's reflection properties*.\n","\n","Without a clear mapping from the physical parameters `(ω, θ)` to the complex budget parameter `gamma` that explicitly links the singularities of `r` to the critical point `gamma_star`, it's challenging to assert that encircling `gamma_star` *must* yield a non-trivial Berry phase related to the physics described by Liu et al. It's possible that the HBAR wall's topological nature, as per Liu et al., is expressed through a different invariant or requires a different parameter space to be explored (e.g., properties of scattering matrix eigenvalues, rather than the phase of `r` or the budget `γ`).\n","\n","Given these points, simply refining the numerical aspects might not resolve the fundamental theoretical mismatch. The next step will attempt to clarify the `gamma_star` and ensure its encirclement, but a deeper dive into the specific topological invariant described by Liu et al. for their reflection coefficient might be needed if discrepancies persist."]},{"cell_type":"markdown","metadata":{"id":"46fd8836"},"source":["**Reasoning**:\n","Based on the theoretical re-evaluation, the next step is to refine the `compute_berry_phase_in_budget_space` function by increasing numerical accuracy and re-executing it. This includes ensuring the `gamma_circle` properly encircles `gamma_star` with more points and analyzing the continued trivial result in the context of the theoretical ambiguities.\n","\n"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"15e0a6ca","executionInfo":{"status":"ok","timestamp":1769927224994,"user_tz":300,"elapsed":24,"user":{"displayName":"Will Lenchus","userId":"03870594209213912784"}},"outputId":"66f44854-3c5c-44ee-e817-875ffe8808ad"},"source":["def compute_berry_phase_in_budget_space(gamma_path, r_values=None):\n","    \"\"\"\n","    Compute the Berry (Pancharatnam) phase for a closed loop in gamma-space.\n","\n","    Parameters:\n","    -----------\n","    gamma_path : array_like, shape (N,)\n","        Complex values of gamma tracing a closed loop (counterclockwise)\n","        around gamma_star = 2 - sqrt(2).\n","        Example: gamma_star + 0.05*exp(1j*linspace(0, 2*pi, 100, endpoint=False))\n","\n","    r_values : array_like, shape (N,), optional\n","        Complex reflection coefficients corresponding to each gamma.\n","        If None, computes phase from budget geometry alone (ideal TEP limit).\n","\n","    Returns:\n","    --------\n","    berry_phase : float\n","        Geometric phase accumulated, in radians.\n","        Expected values:\n","        - 0 or 2π: Trivial topology (no defect enclosed)\n","        - π: Z₂ topological charge (HBAR wall is a branch point)\n","    \"\"\"\n","    gamma_path = np.asarray(gamma_path)\n","    n_points = len(gamma_path)\n","\n","    if r_values is None:\n","        # Ideal TEP state: |ψ> = [√x², i√u] = [√(2γ-1), i√(2(1-γ))]\n","        # This encodes the budget constraint as a complex spinor\n","        # Care must be taken with branch cuts of sqrt for complex gamma.\n","        x_sq = 2*gamma_path - 1\n","        u_val = 2*(1 - gamma_path)\n","\n","        # Use cmath.sqrt for explicit handling of complex square roots, if necessary,\n","        # but numpy handles it for arrays. Ensure consistency of branch cuts.\n","        # For Pancharatnam-Berry phase, the overall phase of the state vector doesn't matter,\n","        # only the relative phase between its components, and the normalization.\n","        psi = np.column_stack([np.sqrt(x_sq), 1j * np.sqrt(u_val)])  # State vectors\n","    else:\n","        # Use actual reflection amplitude/phase as the state\n","        # Normalized: |ψ> ∝ [√T, √R*exp(iφ_r)] where T≈0 at HBAR\n","        r_values = np.asarray(r_values)\n","        R = np.abs(r_values)**2\n","        # Approximate transmission (small at HBAR for thick films)\n","        T = 1 - R  # Energy conservation approximation\n","        psi = np.column_stack([np.sqrt(T), r_values])\n","\n","    # Normalize states (projective Hilbert space)\n","    norms = np.linalg.norm(psi, axis=1, keepdims=True)\n","    psi = psi / norms\n","\n","    # Compute Pancharatnam-Berry phase\n","    # Phase = -Im[sum log(<ψ_i|ψ_{i+1}>)]\n","    overlaps = np.array([np.vdot(psi[i], psi[(i+1) % n_points])\n","                         for i in range(n_points)])\n","\n","    # Total phase is the argument of the product of overlaps\n","    # (U(1) holonomy of the connection)\n","    total_overlap = np.prod(overlaps)\n","    berry_phase = -np.angle(total_overlap)  # Principal value in [-π, π]\n","\n","    # Unwrap to [0, 2π] for clarity\n","    if berry_phase < 0:\n","        berry_phase += 2*np.pi\n","\n","    return berry_phase\n","\n","# ============================================================================\n","# CORRECTED USAGE\n","# ============================================================================\n","\n","# Re-confirm gamma_star based on budget relation: u = 2*(1-gamma) = 2*sqrt(2)-2\n","# This gives 1-gamma = sqrt(2)-1 => gamma = 2-sqrt(2).\n","# So, the original gamma_star = 2 - np.sqrt(2) is consistent with the budget formulation.\n","gamma_star = 2 - np.sqrt(2)  # ≈ 0.586 (This is where x^2 = u)\n","\n","# Create circular path in complex gamma plane around HBAR wall\n","# Radius should be small enough to stay in a meaningful region (e.g., where x_sq and u_val are well-behaved)\n","radius = 0.05 # Keep radius for now, can adjust if numerical issues arise\n","# Increase the number of points for better numerical accuracy of the integral\n","num_points_loop = 1000 # Increased from 100\n","theta_loop = np.linspace(0, 2*np.pi, num_points_loop, endpoint=False)\n","gamma_circle = gamma_star + radius * np.exp(1j * theta_loop)\n","\n","# Use the complex gamma_circle for Berry phase calculation\n","berry = compute_berry_phase_in_budget_space(gamma_circle)\n","\n","print(f\"{'='*60}\")\n","print(f\"BERRY PHASE IN BUDGET SPACE (Refined)\")\n","print(f\"{'='*60}\")\n","print(f\"HBAR budget critical point: γ* = {gamma_star:.6f}\")\n","print(f\"Integration radius: {radius}\")\n","print(f\"Number of points in loop: {num_points_loop}\")\n","print(f\"Calculated Berry phase Φ = {berry:.4f} rad = {np.degrees(berry):.2f}°\")\n","print(f\"{'='*60}\")\n","\n","# Adjusted atol for comparison\n","# Based on theoretical considerations, if a Z2 invariant is expected, it should be pi (not pi/2).\n","# The 2pi result suggests triviality.\n","if np.isclose(berry, np.pi, atol=0.2):\n","    print(\"✓ NON-TRIVIAL TOPOLOGY: HBAR wall carries Z₂ charge (π phase)\")\n","    print(\"  The budget space has a branch cut at γ*\")\n","elif np.isclose(berry, 2*np.pi, atol=0.2) or np.isclose(berry, 0, atol=0.2):\n","    print(\"✗ Trivial topology: No defect detected in budget space\")\n","    print(\"  The result being ~2π suggests the loop encloses no singularity \")\n","    print(\"  or that the budget space formulation doesn't reveal it for this model.\")\n","else:\n","    print(f\"⚠ Intermediate phase: Possible fractional charge or numerical error. Found {berry:.4f}\")\n"],"execution_count":59,"outputs":[{"output_type":"stream","name":"stdout","text":["============================================================\n","BERRY PHASE IN BUDGET SPACE (Refined)\n","============================================================\n","HBAR budget critical point: γ* = 0.585786\n","Integration radius: 0.05\n","Number of points in loop: 1000\n","Calculated Berry phase Φ = 6.1710 rad = 353.57°\n","============================================================\n","✗ Trivial topology: No defect detected in budget space\n","  The result being ~2π suggests the loop encloses no singularity \n","  or that the budget space formulation doesn't reveal it for this model.\n"]}]},{"cell_type":"markdown","metadata":{"id":"87327e93"},"source":["### Analysis of Berry Phase in Budget Space (Refined)\n","\n","Despite increasing the numerical precision (number of points in the integration loop to 1000) and re-executing the `compute_berry_phase_in_budget_space` function, the calculated Berry phase remains approximately `2π` (specifically, `6.1710` radians or `353.57°`). This result consistently indicates a **trivial topology** in the parameter space of the abstract `gamma` budget parameter; meaning, the chosen circular path around `gamma_star = 2 - np.sqrt(2)` does not enclose a topological defect (like a branch point or an exceptional point).\n","\n","This finding aligns with previous observations that the physical `reflection_coefficient` function itself, under the specified parameters, does not exhibit features such as zeros, poles, or sharp `π