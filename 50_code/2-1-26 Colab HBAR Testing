. Eq. (5) for ultrathin conductive film.\n","\n","    Parameters:\n","    -----------\n","    omega : float\n","        Angular frequency [rad/s]\n","    theta_deg : float\n","        Incident angle [degrees]\n","    sigma : float\n","        Conductivity [S/m]\n","    d_f : float\n","        Film thickness [m]\n","\n","    Returns:\n","    --------\n","    r : complex\n","        Complex reflection coefficient\n","    \"\"\"\n","    theta = np.deg2rad(theta_deg)\n","\n","    # Parameters from Liu et al. Eq. (5)-(6)\n","    beta = sigma * omega * mu0 * d_f**2\n","    gamma = np.sqrt(sigma / (omega * eps0)) * np.cos(theta)\n","\n","    # Complex arguments\n","    sqrt_i = np.exp(1j * np.pi/4)  # sqrt(i) = (1+i)/sqrt(2)\n","    sqrt_i_beta = np.sqrt(1j * beta)\n","\n","    # Numerator and denominator from Eq. (5)\n","    numerator = - (1j + gamma**2) * np.sin(sqrt_i_beta)\n","    denominator = (2 * sqrt_i * gamma * np.cos(sqrt_i_beta) +\n","                   (-1j + gamma**2) * np.sin(sqrt_i_beta))\n","\n","    r = numerator / denominator\n","\n","    # Alternative: Full transfer matrix for verification\n","    # (Commented out - use Liu formula as primary)\n","\n","    return r\n","\n","def check_pseudo_brewster_condition(omega, theta, sigma):\n","    \"\"\"\n","    Verifies if condition omega*eps0 = sigma*cos^2(theta) holds.\n","    Returns budget parameter u = A/(A+R) ~ 0.828 at HBAR wall.\n","    \"\"\"\n","    lhs = omega * eps0\n","    rhs = sigma * np.cos(np.deg2rad(theta))**2\n","    ratio = lhs / rhs\n","    # At exact HBAR: ratio = 1\n","    # Budget fraction u = 2*sqrt(2)-2 when ratio = 1\n","    return ratio\n","\n","def compute_phase_map(omega_range, theta_range, sigma, d_f):\n","    \"\"\"\n","    Compute reflection phase phi = arg(r) on a grid.\n","    \"\"\"\n","    n_omega = len(omega_range)\n","    n_theta = len(theta_range)\n","    phi = np.zeros((n_omega, n_theta))\n","\n","    for i, w in enumerate(omega_range):\n","        for j, th in enumerate(theta_range):\n","            r = reflection_coefficient(w, th, sigma, d_f)\n","            phi[i, j] = np.angle(r)  # Arg in [-pi, pi]\n","\n","    return phi\n","\n","def unwrap_phase_2d(phi):\n","    \"\"\"\n","    2D phase unwrapping to handle branch cuts.\n","    Simple method: cumulative sum along axes.\n","    \"\"\"\n","    # Unwrap along omega (rows), then theta (cols)\n","    phi_unwrapped = np.unwrap(phi, axis=0)\n","    phi_unwrapped = np.unwrap(phi_unwrapped, axis=1)\n","    return phi_unwrapped\n","\n","def compute_topological_charge(phi, omega_vals, theta_vals,\n","                               omega_idx_min, omega_idx_max,\n","                               theta_idx_min, theta_idx_max):\n","    \"\"\"\n","    Compute Q = (1/2pi) * contour integral of d(phi) around\n","    rectangular loop defined by grid indices.\n","\n","    Contour goes: right -> up -> left -> down (counterclockwise)\n","    \"\"\"\n","    phi_rect = phi[omega_idx_min:omega_idx_max+1, theta_idx_min:theta_idx_max+1]\n","    omega_rect = omega_vals[omega_idx_min:omega_idx_max+1]\n","    theta_rect = theta_vals[theta_idx_min:theta_idx_max+1]\n","\n","    # Extract loop values (counterclockwise)\n","    # Bottom edge (rightward)\n","    bottom = phi_rect[0, :]\n","    # Right edge (upward)\n","    right = phi_rect[:, -1]\n","    # Top edge (leftward, reversed)\n","    top = phi_rect[-1, ::-1]\n","    # Left edge (downward, reversed)\n","    left = phi_rect[::-1, 0]\n","\n","    # Concatenate (avoid double counting corners)\n","    loop_values = np.concatenate([\n","        bottom[:-1],\n","        right[:-1],\n","        top[:-1],\n","        left[:-1]\n","    ])\n","\n","    # Compute discrete integral of d(phi)\n","    dphi = np.diff(loop_values, append=loop_values[0])\n","    total_phase = np.sum(dphi)\n","\n","    # Winding number\n","    Q = total_phase / (2 * np.pi)\n","\n","    return Q, loop_values\n","\n","# ============================================================================\n","# MAIN ANALYSIS\n","# ============================================================================\n","\n","if __name__ == \"__main__\":\n","    # Parameters from Liu et al. Fig. 2, point P2 (crucial case)\n","    # sigma = 1.12e5 S/m, d_f = 10e-6 m (10 microns)\n","    # Frequency = 0.3 THz\n","\n","    f0 = 0.3e12  # 0.3 THz\n","    omega0 = 2*np.pi*f0\n","    sigma = 1.12e5  # Point P2 conductivity\n","    d_f = 10e-6     # Film thickness\n","\n","    # Grid around critical point (theta -> 90°, omega near resonance)\n","    # Critical angle for P2: theta_c = arccos(sqrt(omega*eps0/sigma))\n","    theta_c = np.arccos(np.sqrt(omega0 * eps0 / sigma))\n","    theta_c_deg = np.rad2deg(theta_c)\n","    print(f\"Pseudo-Brewster angle: {theta_c_deg:.2f}°\")\n","    print(f\"Target HBAR angle: ~89.3° (from paper)\")\n","\n","    # Range: theta from 89° to 90°, omega around 0.3 THz\n","    theta_range = np.linspace(88.5, 89.5, 300)  # Near grazing\n","    omega_range = np.linspace(0.28e12, 0.32e12, 300)  # Around 0.3 THz\n","\n","    # Compute phase map\n","    print(\"Computing phase map...\")\n","    phi = compute_phase_map(omega_range, theta_range, sigma, d_f)\n","    phi_unwrapped = unwrap_phase_2d(phi)\n","\n","    # Find indices closest to critical point\n","    # Critical point is where absorption peaks (82.8%)\n","    # From paper: theta ~ 89.3° for P2\n","\n","    theta_crit_idx = np.argmin(np.abs(theta_range - 89.3))\n","    omega_crit_idx = np.argmin(np.abs(omega_range - omega0))\n","\n","    # Define rectangular contour around critical point\n","    # Size: +/- 5 grid points in each direction\n","    delta = 50\n","    o_min, o_max = max(0, omega_crit_idx-delta), min(len(omega_range)-1, omega_crit_idx+delta)\n","    t_min, t_max = max(0, theta_crit_idx-delta), min(len(theta_range)-1, theta_crit_idx+delta)\n","\n","    # Calculate Absorption map here, so it's available for critical exponent calculation\n","    A_map = np.zeros_like(phi)\n","    for i, w in enumerate(omega_range):\n","        for j, th in enumerate(theta_range):\n","            r = reflection_coefficient(w, th, sigma, d_f)\n","            t = 2*np.sqrt(1j*sigma/(w*eps0))*np.cos(np.deg2rad(th)) / \\\n","                (2*np.sqrt(1j)*np.sqrt(sigma/(w*eps0))*np.cos(np.deg2rad(th)) +\n","                 (-1j + sigma/(w*eps0)*(np.cos(np.deg2rad(th)))**2)*np.sin(np.sqrt(1j*sigma*w*mu0*d_f**2)))\n","            A_map[i,j] = 1 - np.abs(r)**2 - np.abs(t)**2\n","\n","    # Fit the approach to HBAR wall for critical exponent\n","    dtheta = 90.0 - theta_range[theta_crit_idx-10:theta_crit_idx+1]\n","    dA = (2*np.sqrt(2)-2) - A_map[omega_crit_idx, theta_crit_idx-10:theta_crit_idx+1]\n","\n","    # Fit to power law dA ~ dtheta^nu\n","    log_dtheta = np.log(dtheta)\n","    log_dA = np.log(np.abs(dA) + 1e-10)  # avoid log(0)\n","\n","    coeffs = np.polyfit(log_dtheta, log_dA, 1)\n","    nu = coeffs[0]  # Slope = critical exponent\n","\n","    print(f\"Critical exponent nu = {nu:.3f}\")\n","    print(f\"TEP prediction: nu = 0.5 or 1.0 (metric singularity)\")\n","    print(f\"Standard EM: nu = 2.0 (Gaussian) or 1.0 (Lorentzian)\")\n","\n","    # Check absorption at critical point\n","    r_crit = reflection_coefficient(omega0, 89.3, sigma, d_f)\n","    R = np.abs(r_crit)**2\n","    # Transmission (approximate, from Liu et al. t formula)\n","    # For thin film at grazing, check budget partition\n","    A_approx = 1 - R  # Assuming T->0 at HBAR wall (d_f >> delta)\n","\n","    print(f\"\\nReflection at 89.3°: {R:.4f} (Expected: 0.172)\")\n","    print(f\"Absorption: {A_approx:.4f} (Expected: 0.828)\")\n","\n","    # Budget ratio check\n","    if A_approx > 0.8:\n","        print(\"✓ HBAR wall condition satisfied (A ≈ 82.8%)\")\n","\n","    # Visualization\n","    fig, axes = plt.subplots(1, 3, figsize=(15, 4))\n","\n","    # 1. Phase map\n","    im1 = axes[0].imshow(phi_unwrapped, origin='lower', aspect='auto',\n","                        extent=[theta_range[0], theta_range[-1],\n","                               omega_range[0]/1e12, omega_range[-1]/1e12],\n","                        cmap='twilight')\n","    axes[0].set_xlabel('Incident angle θ (degrees)')\n","    axes[0].set_ylabel('Frequency (THz)')\n","    axes[0].set_title('Reflection phase φ(ω, θ)')\n","\n","    # Draw contour rectangle\n","    rect_omega = [omega_range[o_min]/1e12, omega_range[o_max]/1e12]\n","    rect_theta = [theta_range[t_min], theta_range[t_max]]\n","    rect = plt.Rectangle((rect_theta[0], rect_omega[0]),\n","                        rect_theta[1]-rect_theta[0],\n","                        rect_omega[1]-rect_omega[0],\n","                        fill=False, edgecolor='red', linewidth=2)\n","    axes[0].add_patch(rect)\n","    axes[0].plot(89.3, 0.3, 'g+', markersize=10, mew=2, label='HBAR wall')\n","    axes[0].legend()\n","    plt.colorbar(im1, ax=axes[0])\n","\n","    # 2. Absorption map (for reference)\n","    im2 = axes[1].imshow(A_map, origin='lower', aspect='auto',\n","                        extent=[theta_range[0], theta_range[-1],\n","                               omega_range[0]/1e12, omega_range[-1]/1e12],\n","                        cmap='hot', vmin=0, vmax=1)\n","    axes[1].set_xlabel('Incident angle θ (degrees)')\n","    axes[1].set_ylabel('Frequency (THz)')\n","    axes[1].set_title('Absorption A(ω, θ)')\n","    plt.colorbar(im2, ax=axes[1], label='Absorption')\n","    axes[1].axvline(89.3, color='cyan', linestyle='--', label='HBAR angle')\n","    axes[1].legend()\n","\n","    # Calculate topological charge\n","    Q, loop = compute_topological_charge(phi_unwrapped, omega_range, theta_range,\n","                                          o_min, o_max, t_min, t_max)\n","\n","    print(f\"\\n{'='*60}\")\n","    print(f\"TOPOLOGICAL CHARGE ANALYSIS\")\n","    print(f\"{'='*60}\")\n","    print(f\"Winding number Q = {Q:.4f}\")\n","    print(f\"Expected TEP value: Q ≈ 1.0 (integer)\")\n","    print(f\"Expected Standard EM: Q ≈ 0.0 (no topological constraint)\")\n","    print(f\"{'='*60}\")\n","\n","    # 3. Winding demonstration\n","    axes[2].plot(loop, 'b.-', label='Phase around contour')\n","    axes[2].axhline(0, color='k', linestyle='--', alpha=0.3)\n","    axes[2].set_xlabel('Index along contour')\n","    axes[2].set_ylabel('Phase φ [radians]')\n","    axes[2].set_title(f'Phase winding: Q = {Q:.2f}')\n","    axes[2].grid(True)\n","    axes[2].text(0.5, 0.95, f'Total winding: {Q:.4f}',\n","                transform=axes[2].transAxes, ha='center', va='top',\n","                bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5))\n","\n","    plt.tight_layout()\n","    plt.savefig('tep_topological_analysis.png', dpi=150)\n","    plt.show()\n","\n","    # Additional TEP test: Check if budget ratio is silver ratio\n","    print(f\"\\n{'='*60}\")\n","    print(\"HBAR BUDGET VERIFICATION\")\n","    print(f\"{'='*60}\")\n","    print(f\"Absorption (u): {A_approx:.6f}\")\n","    print(f\"Reflection (x²): {R:.6f}\")\n","    print(f\"Sum: {A_approx + R:.6f} (should be ~1)\")\n","\n","    silver_u = 2*np.sqrt(2) - 2  # 0.828...\n","    silver_x2 = 3 - 2*np.sqrt(2)  # 0.172...\n","\n","    print(f\"\\nSilver ratio predictions:\")\n","    print(f\"  u = 2√2 - 2 = {silver_u:.6f}\")\n","    print(f\"  x² = 3 - 2√2 = {silver_x2:.6f}\")\n","\n","    print(f\"\\nMatch to HBAR wall:\")\n","    print(f\"  |u - u_silver|/u_silver = {np.abs(A_approx - silver_u)/silver_u:.4%}\")\n","    print(f\"  |x² - x²_silver|/x²_silver = {np.abs(R - silver_x2)/silver_x2:.4%}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":667},"id":"xSiAiQ3BSAka","executionInfo":{"status":"ok","timestamp":1769925621317,"user_tz":300,"elapsed":6307,"user":{"displayName":"Will Lenchus","userId":"03870594209213912784"}},"outputId":"92470017-b6c7-4c31-88ec-389847719ca3"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Pseudo-Brewster angle: 89.30°\n","Target HBAR angle: ~89.3°